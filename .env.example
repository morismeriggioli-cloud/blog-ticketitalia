# Anthropic
ANTHROPIC_API_KEY=

# Resend (https://resend.com) — API key e mittente verificato
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Notifiche
NOTIFY_EMAIL=

# Blog
SITE_URL=https://blog.ticketitalia.com

# Newsletter — Brevo (https://www.brevo.com)
# La chiave sta SOLO lato server: la legge /api/subscribe. Va impostata sul
# servizio che serve il blog (Vercel / il Railway che esegue `next start`).
API_KEY_BLOG_BREVO=
# Id numerico della lista contatti Brevo a cui aggiungere gli iscritti (opzionale)
BREVO_LIST_ID=

# Approve server (URL raggiungibile da chi riceve l'email)
APPROVE_SERVER_URL=http://localhost:3001
# Token segreto richiesto da approve-server (>= 24 char). Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVE_SERVER_TOKEN=
# Bind/porta opzionali (default 127.0.0.1:3001)
APPROVE_SERVER_BIND=127.0.0.1
APPROVE_SERVER_PORT=3001
