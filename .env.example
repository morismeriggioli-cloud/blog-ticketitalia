# Anthropic
ANTHROPIC_API_KEY=

# Resend (https://resend.com) — API key e mittente verificato
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Notifiche
NOTIFY_EMAIL=

# Blog
SITE_URL=https://blog.ticketitalia.com

# Approve server (URL raggiungibile da chi riceve l'email)
APPROVE_SERVER_URL=http://localhost:3001
# Token segreto richiesto da approve-server (>= 24 char). Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVE_SERVER_TOKEN=
# Bind/porta opzionali (default 127.0.0.1:3001)
APPROVE_SERVER_BIND=127.0.0.1
APPROVE_SERVER_PORT=3001
